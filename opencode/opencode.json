{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow"
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GH_MCP_PAT}"
      }
    }
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini"
    }
  }
}
